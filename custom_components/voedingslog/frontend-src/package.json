{
  "name": "voedingslog-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/voedingslog-panel.ts --bundle --format=esm --minify --outfile=../frontend/voedingslog-panel.js",
    "watch": "pnpm build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
